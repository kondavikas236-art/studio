{
  "entities": {
    "ParentProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ParentProfile",
      "type": "object",
      "description": "Represents a parent or guardian who manages one or more child profiles and receives reports and notifications.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ParentProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The email address of the parent.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the parent."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the parent."
        },
        "isPro": {
          "type": "boolean",
          "description": "Whether the parent has an active Pro subscription."
        },
        "subscriptionTier": {
          "type": "string",
          "enum": ["free", "family_pro"],
          "description": "The current subscription tier."
        },
        "receiveWeeklyReportEmail": {
          "type": "boolean",
          "description": "A flag for weekly reports."
        },
        "weeklyReportDayOfWeek": {
          "type": "string",
          "description": "Preferred day for reports."
        },
        "weeklyReportSendTime": {
          "type": "string",
          "description": "Preferred time for reports.",
          "format": "time"
        }
      },
      "required": [
        "id",
        "email",
        "firstName",
        "lastName",
        "isPro"
      ]
    },
    "ChildProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChildProfile",
      "type": "object",
      "description": "Represents a child user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "parentId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date"
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri"
        },
        "dailyScreenTimeLimitMinutes": {
          "type": "number"
        },
        "gamingTimeLimitMinutes": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "parentId",
        "name",
        "dateOfBirth"
      ]
    },
    "AppUsageSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppUsageSession",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "childId": { "type": "string" },
        "parentId": { "type": "string" },
        "appName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["id", "childId", "parentId", "appName", "startTime", "endTime", "durationMinutes"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/parentProfiles/{parentId}",
        "definition": {
          "entityName": "parentProfile",
          "schema": {
            "$ref": "#/backend/entities/ParentProfile"
          },
          "description": "Stores individual parent profiles and subscription status."
        }
      },
      {
        "path": "/parentProfiles/{parentId}/childProfiles/{childId}",
        "definition": {
          "entityName": "childProfile",
          "schema": {
            "$ref": "#/backend/entities/ChildProfile"
          },
          "description": "Child profiles managed by the parent."
        }
      }
    ]
  }
}